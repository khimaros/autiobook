# LLM provider API keys (set the ones you need)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...

# override llm model - MUST include provider prefix
# see https://docs.litellm.ai/docs/providers for full list
# examples:
#   AUTIOBOOK_LLM_MODEL=openai/gpt-4o
#   AUTIOBOOK_LLM_MODEL=anthropic/claude-3-5-sonnet-20240620
#   AUTIOBOOK_LLM_MODEL=gemini/gemini-1.5-pro
#   AUTIOBOOK_LLM_MODEL=openai/my-local-model  (for OpenAI-compatible endpoints)
# AUTIOBOOK_LLM_MODEL=openai/gpt-4o

# override tts models (defaults target Qwen3-TTS variants):
#   CLONE    - voice cloning from reference audio (perform/dramatize)
#   INSTRUCT - preset instructable voices by name (synthesize)
#   DESIGN   - generate new voices from text descriptions (audition)
# AUTIOBOOK_TTS_CLONE_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-Base
# AUTIOBOOK_TTS_INSTRUCT_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice
# AUTIOBOOK_TTS_DESIGN_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-VoiceDesign

# optional: tokens for extended thinking (default: 0 = disabled)
# AUTIOBOOK_LLM_THINKING_BUDGET=1024

# optional: chapters per cast-generation batch (default: 3)
# AUTIOBOOK_CAST_BATCH_SIZE=3

# optional: deterministic seed for tts and llm (unset = concrete random each run)
# AUTIOBOOK_SEED=31337

# optional: custom OpenAI-compatible endpoint (use with openai/ prefix)
# OPENAI_BASE_URL=http://localhost:8080/v1
